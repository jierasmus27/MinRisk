<%= form_with model: company, class: "space-y-4" do |f| %>
  <% if company.errors.any? %>
    <ul class="text-error text-sm list-disc pl-5">
      <% company.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-on-surface mb-1" %>
    <%= f.text_field :name, class: "w-full border border-outline-variant rounded p-2" %>
  </div>
  <div>
    <%= f.label :address_line1, class: "block text-sm font-medium text-on-surface mb-1" %>
    <%= f.text_field :address_line1, class: "w-full border border-outline-variant rounded p-2" %>
  </div>
  <div>
    <%= f.label :address_line2, class: "block text-sm font-medium text-on-surface mb-1" %>
    <%= f.text_field :address_line2, class: "w-full border border-outline-variant rounded p-2" %>
  </div>
  <div>
    <%= f.label :city, class: "block text-sm font-medium text-on-surface mb-1" %>
    <%= f.text_field :city, class: "w-full border border-outline-variant rounded p-2" %>
  </div>
  <div>
    <%= f.label :country_iso, "Country (ISO alpha-2)", class: "block text-sm font-medium text-on-surface mb-1" %>
    <%= f.text_field :country_iso, maxlength: 2, class: "w-full border border-outline-variant rounded p-2 uppercase" %>
  </div>
  <div>
    <%= f.label :logo, class: "block text-sm font-medium text-on-surface mb-1" %>
    <%= f.file_field :logo, accept: "image/png,image/jpeg,image/webp", class: "w-full text-sm" %>
  </div>

  <div class="flex gap-3 pt-4">
    <%= f.submit class: "bg-primary text-on-primary px-4 py-2 rounded font-semibold" %>
    <%= link_to "Cancel", companies_path, class: "px-4 py-2 border border-outline-variant rounded" %>
  </div>
<% end %>
