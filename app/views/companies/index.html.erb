<% content_for :title, "Dashboard - MinRisk" %>

<%= render "shared/page_header",
      title: "Dashboard",
      subtitle: "Manage companies and their projects." %>

<div class="p-6 flex-1 max-w-7xl mx-auto w-full">
  <section class="<%= card_class %>">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 <%= card_title_bar_class %>">
      <h2 class="<%= card_title_class %>">Companies</h2>
      <%= link_to new_company_path, class: outline_button_class do %>
        <span class="material-symbols-outlined text-[18px]">add</span>
        New company
      <% end %>
    </div>

    <% if @companies.any? %>
      <ul class="divide-y divide-outline-variant -mx-6">
        <% @companies.each do |company| %>
          <%= render "company_row", company: company %>
        <% end %>
      </ul>
    <% else %>
      <p class="<%= body_text_class %>">No companies yet. Create one to get started.</p>
    <% end %>
  </section>
</div>
