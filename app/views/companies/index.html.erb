<div class="max-w-3xl mx-auto p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="font-headline-md text-headline-md text-primary">Companies</h1>
    <%= link_to "New company", new_company_path, class: "text-primary font-semibold underline" %>
  </div>
  <ul class="divide-y divide-outline-variant border border-outline-variant rounded-lg bg-surface-container-lowest">
    <% @companies.each do |company| %>
      <li class="p-4 flex justify-between items-center hover:bg-surface-container-low">
        <%= link_to company.name, company, class: "font-body-lg text-on-surface font-medium" %>
        <%= link_to "Projects", company_projects_path(company), class: "text-sm text-on-primary-container font-semibold" %>
      </li>
    <% end %>
  </ul>
  <% if @companies.empty? %>
    <p class="mt-4 text-on-surface-variant font-body-md">No companies yet. Create one to get started.</p>
  <% end %>
</div>
