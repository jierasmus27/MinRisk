<section class="<%= card_class %> overflow-hidden !p-0">
  <div class="px-6 pt-6 pb-2 border-b border-outline-variant bg-surface-container-low">
    <h2 class="<%= card_title_class %>">Project Summary</h2>
  </div>

  <div class="grid grid-cols-2 border-b border-outline-variant">
    <div class="p-4 border-r border-outline-variant space-y-2">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 rounded bg-on-tertiary-fixed-variant/10 flex items-center justify-center">
          <span class="material-symbols-outlined text-on-tertiary-fixed-variant text-[20px]">analytics</span>
        </div>
        <div class="flex flex-col">
          <span class="font-tabular-numeric text-tabular-numeric text-lg font-bold text-on-surface"><%= import_count %></span>
          <span class="<%= section_label_class %>">Imports</span>
        </div>
      </div>
      <p class="font-label-caps text-label-caps text-on-surface-variant">
        <% if last_import %>
          Last: <%= time_ago_in_words(last_import.created_at) %> ago
        <% else %>
          No imports yet
        <% end %>
      </p>
    </div>
    <div class="p-4 space-y-2">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 rounded bg-secondary-container/10 flex items-center justify-center">
          <span class="material-symbols-outlined text-secondary text-[20px]">inventory_2</span>
        </div>
        <div class="flex flex-col">
          <span class="font-tabular-numeric text-tabular-numeric text-lg font-bold text-on-surface"><%= package_count %></span>
          <span class="<%= section_label_class %>">Packages</span>
        </div>
      </div>
      <p class="font-label-caps text-label-caps text-on-surface-variant">
        <%= project.line_items.count %> line items
      </p>
    </div>
  </div>

  <div class="grid grid-cols-2">
    <div class="p-4 border-r border-outline-variant space-y-2">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 rounded bg-on-tertiary-container/10 flex items-center justify-center">
          <span class="material-symbols-outlined text-on-tertiary-container text-[20px]">group</span>
        </div>
        <div class="flex flex-col">
          <span class="font-tabular-numeric text-tabular-numeric text-lg font-bold text-on-surface">—</span>
          <span class="<%= section_label_class %>">Members</span>
        </div>
      </div>
      <p class="font-label-caps text-label-caps text-on-surface-variant">Coming soon</p>
    </div>
    <div class="p-4 space-y-2">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 rounded bg-on-secondary-container/10 flex items-center justify-center">
          <span class="material-symbols-outlined text-on-secondary-container text-[20px]">event_available</span>
        </div>
        <div class="flex flex-col">
          <span class="font-tabular-numeric text-tabular-numeric text-lg font-bold text-on-surface"><%= l project.created_at, format: "%b %d" %></span>
          <span class="<%= section_label_class %>">Created</span>
        </div>
      </div>
      <p class="font-label-caps text-label-caps text-on-surface-variant"><%= project.currency_iso %></p>
    </div>
  </div>
</section>
