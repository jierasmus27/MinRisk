<%= form_with model: [ company, project ], class: "space-y-4" do |f| %>
  <% if project.errors.any? %>
    <ul class="text-error text-sm list-disc pl-5">
      <% project.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-on-surface mb-1" %>
    <%= f.text_field :name, class: "w-full border border-outline-variant rounded p-2" %>
  </div>
  <div>
    <%= f.label :code, class: "block text-sm font-medium text-on-surface mb-1" %>
    <%= f.text_field :code, class: "w-full border border-outline-variant rounded p-2" %>
  </div>
  <div>
    <%= f.label :description, class: "block text-sm font-medium text-on-surface mb-1" %>
    <%= f.text_area :description, rows: 3, class: "w-full border border-outline-variant rounded p-2" %>
  </div>
  <div>
    <%= f.label :currency_iso, "Currency (ISO 4217)", class: "block text-sm font-medium text-on-surface mb-1" %>
    <%= f.text_field :currency_iso, maxlength: 3, class: "w-full border border-outline-variant rounded p-2 uppercase" %>
  </div>
  <div>
    <%= f.label :time_zone, class: "block text-sm font-medium text-on-surface mb-1" %>
    <%= f.collection_select :time_zone, ActiveSupport::TimeZone.all, :name, :to_s,
          { selected: project.time_zone.presence || "UTC" },
          class: "w-full border border-outline-variant rounded p-2 bg-surface" %>
  </div>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :start_date, class: "block text-sm font-medium text-on-surface mb-1" %>
      <%= f.date_field :start_date, class: "w-full border border-outline-variant rounded p-2" %>
    </div>
    <div>
      <%= f.label :target_end_date, class: "block text-sm font-medium text-on-surface mb-1" %>
      <%= f.date_field :target_end_date, class: "w-full border border-outline-variant rounded p-2" %>
    </div>
  </div>
  <div>
    <%= f.label :monte_carlo_iterations, class: "block text-sm font-medium text-on-surface mb-1" %>
    <%= f.number_field :monte_carlo_iterations, class: "w-full border border-outline-variant rounded p-2" %>
  </div>
  <fieldset>
    <legend class="block text-sm font-medium text-on-surface mb-2">Confidence levels</legend>
    <div class="flex flex-wrap gap-3">
      <% (10..90).step(10).each do |pct| %>
        <label class="inline-flex items-center gap-1 text-sm">
          <%= check_box_tag "project[confidence_levels][]", pct, project.confidence_levels.include?(pct), id: "project_confidence_#{pct}" %>
          <span>P<%= pct %></span>
        </label>
      <% end %>
    </div>
    <%= hidden_field_tag "project[confidence_levels][]", "" %>
  </fieldset>
  <div>
    <%= f.label :estimate_accuracy_class, class: "block text-sm font-medium text-on-surface mb-1" %>
    <%= f.select :estimate_accuracy_class,
          [ [ "Class 2 (Detailed)", "class_2" ], [ "Class 3 (Semi-Detailed)", "class_3" ], [ "Class 4 (Study)", "class_4" ] ],
          { include_blank: "—" },
          class: "w-full border border-outline-variant rounded p-2" %>
  </div>
  <div>
    <%= f.label :base_year, class: "block text-sm font-medium text-on-surface mb-1" %>
    <%= f.number_field :base_year, class: "w-full border border-outline-variant rounded p-2" %>
  </div>
  <div>
    <%= f.label :logo, class: "block text-sm font-medium text-on-surface mb-1" %>
    <%= f.file_field :logo, accept: "image/png,image/jpeg,image/webp", class: "w-full text-sm" %>
  </div>

  <div class="flex gap-3 pt-4">
    <%= f.submit class: "bg-primary text-on-primary px-4 py-2 rounded font-semibold" %>
    <%= link_to "Cancel", company_projects_path(company), class: "px-4 py-2 border border-outline-variant rounded" %>
  </div>
<% end %>
