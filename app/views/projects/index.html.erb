<% content_for :title, "Projects · #{@company.name} - MinRisk" %>

<%= render "shared/page_header",
      title: "Project settings",
      subtitle: @company.name %>

<div class="p-6 flex-1 max-w-7xl mx-auto w-full space-y-6">
  <p class="<%= body_text_class %>">
    <%= link_to "← Back to dashboard", companies_path, class: "text-primary hover:underline" %>
  </p>

  <section class="<%= card_class %>">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 <%= card_title_bar_class %>">
      <h2 class="<%= card_title_class %>">Projects</h2>
      <%= link_to new_company_project_path(@company), class: outline_button_class do %>
        <span class="material-symbols-outlined text-[18px]">add</span>
        New project
      <% end %>
    </div>

    <% if @projects.any? %>
      <ul class="divide-y divide-outline-variant -mx-6">
        <% @projects.each do |project| %>
          <%= render "project_row", company: @company, project: project %>
        <% end %>
      </ul>
    <% else %>
      <p class="<%= body_text_class %>">No projects yet. Create one to configure settings and upload scope data.</p>
    <% end %>
  </section>
</div>
