<section class="md:col-span-12 <%= card_class %>">
  <h2 class="<%= card_title_class %> <%= card_title_bar_class %>">Additional Settings</h2>

  <div class="-mx-6 divide-y divide-outline-variant">
    <div class="px-6 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-center gap-4 min-w-0">
        <div class="w-10 h-10 rounded-full bg-emerald-50 flex items-center justify-center shrink-0">
          <span class="material-symbols-outlined text-emerald-600">payments</span>
        </div>
        <div class="min-w-0">
          <p class="font-body-md text-body-md font-semibold text-on-surface">Cost Settings</p>
          <p class="<%= body_text_class %>">Manage WBS structure, unit costs, and inflation profiles.</p>
        </div>
      </div>
      <button type="button" disabled class="shrink-0 px-4 py-2 border border-outline-variant rounded-lg font-label-caps text-label-caps text-primary opacity-50 cursor-not-allowed uppercase tracking-wide">Configure</button>
    </div>

    <div class="px-6 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-center gap-4 min-w-0">
        <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center shrink-0">
          <span class="material-symbols-outlined text-red-600">shield</span>
        </div>
        <div class="min-w-0">
          <p class="font-body-md text-body-md font-semibold text-on-surface">Risk Settings</p>
          <p class="<%= body_text_class %>">Define risk scoring matrices, probability distributions, and impacts.</p>
        </div>
      </div>
      <button type="button" disabled class="shrink-0 px-4 py-2 border border-outline-variant rounded-lg font-label-caps text-label-caps text-primary opacity-50 cursor-not-allowed uppercase tracking-wide">Configure</button>
    </div>

    <div class="px-6 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-center gap-4 min-w-0">
        <div class="w-10 h-10 rounded-full bg-purple-50 flex items-center justify-center shrink-0">
          <span class="material-symbols-outlined text-purple-600">settings_input_component</span>
        </div>
        <div class="min-w-0">
          <p class="font-body-md text-body-md font-semibold text-on-surface">Custom Fields</p>
          <p class="<%= body_text_class %>">Add metadata fields for advanced project tracking and sorting.</p>
        </div>
      </div>
      <button type="button" disabled class="shrink-0 px-4 py-2 border border-outline-variant rounded-lg font-label-caps text-label-caps text-primary opacity-50 cursor-not-allowed uppercase tracking-wide">Manage</button>
    </div>

    <div class="px-6 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-center gap-4 min-w-0">
        <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center shrink-0">
          <span class="material-symbols-outlined text-blue-600">extension</span>
        </div>
        <div class="min-w-0">
          <p class="font-body-md text-body-md font-semibold text-on-surface">Integrations</p>
          <p class="<%= body_text_class %>">Connect to P6, MS Project, or SAP for direct data synchronization.</p>
        </div>
      </div>
      <button type="button" disabled class="shrink-0 px-4 py-2 border border-outline-variant rounded-lg font-label-caps text-label-caps text-primary opacity-50 cursor-not-allowed uppercase tracking-wide">Manage</button>
    </div>
  </div>
</section>
