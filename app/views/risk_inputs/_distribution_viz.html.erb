<% active_distribution = distribution_type.presence || "triangular" %>

<div class="w-full bg-surface rounded border border-outline-variant px-3 py-2"
     data-risk-inputs-target="distributionViz"
     data-driver-type="<%= driver_type %>">
  <div class="h-16 flex items-end justify-center relative">
    <svg class="w-full h-full <%= risk_driver_viz_color_class(driver_type) %>" viewBox="0 0 200 80" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g data-distribution="triangular" class="<%= active_distribution == "triangular" ? "" : "hidden" %>">
        <path d="M 20 70 L 100 10 L 180 70" stroke="currentColor" stroke-width="2" />
        <path d="M 20 70 L 100 10 L 180 70 Z" fill="currentColor" fill-opacity="0.12" />
        <line x1="100" y1="10" x2="100" y2="70" stroke="currentColor" stroke-width="1" stroke-dasharray="2,2" />
      </g>

      <g data-distribution="lognormal" class="<%= active_distribution == "lognormal" ? "" : "hidden" %>">
        <path d="M 10 70 Q 45 8, 90 38 T 190 70" stroke="currentColor" stroke-width="2" />
        <path d="M 10 70 Q 45 8, 90 38 T 190 70 Z" fill="currentColor" fill-opacity="0.12" />
      </g>

      <g data-distribution="normal" class="<%= active_distribution == "normal" ? "" : "hidden" %>">
        <path d="M 10 70 Q 60 5, 100 28 Q 140 5, 190 70" stroke="currentColor" stroke-width="2" />
        <path d="M 10 70 Q 60 5, 100 28 Q 140 5, 190 70 Z" fill="currentColor" fill-opacity="0.12" />
      </g>

      <g data-distribution="uniform" class="<%= active_distribution == "uniform" ? "" : "hidden" %>">
        <path d="M 30 70 L 30 30 L 170 30 L 170 70" stroke="currentColor" stroke-width="2" />
        <path d="M 30 70 L 30 30 L 170 30 L 170 70 Z" fill="currentColor" fill-opacity="0.12" />
      </g>
    </svg>
  </div>
  <div class="mt-1 flex justify-between text-[10px] text-on-surface-variant font-semibold">
    <span data-role="viz-min"><%= number_to_percentage(min_pct, precision: 1, strip_insignificant_zeros: true) %></span>
    <span>Most Likely</span>
    <span data-role="viz-max"><%= number_to_percentage(max_pct, precision: 1, strip_insignificant_zeros: true) %></span>
  </div>
</div>
