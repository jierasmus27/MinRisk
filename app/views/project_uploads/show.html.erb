<% content_for :title, "Data Upload & Validation - MinRisk" %>

<div class="px-6 py-8 border-b border-outline-variant bg-surface-container-lowest">
  <h1 class="font-headline-lg text-headline-lg text-primary">Data Upload &amp; Validation</h1>
  <p class="font-body-md text-body-md text-on-surface-variant mt-2">Import cost estimation data sources and configure parameters for risk analysis.</p>
</div>

<div class="p-6 flex-1 flex flex-col gap-6 max-w-7xl mx-auto w-full">
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
    <div class="xl:col-span-2 bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm flex flex-col">
      <h2 class="font-headline-md text-headline-md text-primary mb-4 border-b border-outline-variant pb-2">Upload Data Source</h2>

      <%= form_with url: company_project_upload_path(@company, @project), method: :post, multipart: true, class: "flex flex-col gap-4" do %>
        <label for="upload-file-input" class="flex-1 border-2 border-dashed border-outline-variant hover:border-primary-container bg-surface rounded-lg flex flex-col items-center justify-center p-10 transition-colors cursor-pointer group min-h-[240px]">
          <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center mb-4 group-hover:bg-tertiary-fixed transition-colors">
            <span class="material-symbols-outlined text-3xl text-on-surface-variant group-hover:text-primary-container transition-colors">cloud_upload</span>
          </div>
          <p class="font-body-lg text-body-lg text-on-surface font-semibold mb-1">Drag and drop Excel files here</p>
          <p class="font-body-md text-body-md text-on-surface-variant mb-6 text-center">or click to browse from your computer (.xlsx, .csv)</p>
          <%= file_field_tag :file, accept: ".xlsx,.csv,text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", class: "sr-only", id: "upload-file-input" %>
          <span class="bg-primary-container text-on-primary-container px-6 py-2 rounded border border-outline-variant font-label-caps text-label-caps hover:bg-surface-tint transition-colors uppercase pointer-events-none">Browse Files</span>
        </label>
        <%= submit_tag "Upload file", class: "self-end bg-primary text-on-primary px-4 py-2 rounded font-body-md font-semibold" %>
      <% end %>

      <% if @imports.any? %>
        <div class="mt-4">
          <h3 class="font-label-caps text-label-caps text-on-surface-variant uppercase mb-2">Recent imports</h3>
          <ul class="space-y-2">
            <% @imports.each do |imp| %>
              <li class="flex items-center justify-between p-2 border border-outline-variant rounded bg-surface">
                <div class="flex items-center gap-4 min-w-0">
                  <span class="material-symbols-outlined text-primary-container shrink-0">description</span>
                  <div class="min-w-0">
                    <p class="font-body-md text-on-surface font-medium truncate"><%= imp.file.filename %></p>
                    <p class="font-code-data text-code-data text-on-surface-variant"><%= imp.status %> · <%= l imp.created_at, format: :short %></p>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>

    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm flex flex-col">
      <h2 class="font-headline-md text-headline-md text-primary mb-4 border-b border-outline-variant pb-2">Scope Parameters</h2>
      <%= form_with model: [@company, @project], class: "flex flex-col gap-4" do |f| %>
        <div>
          <%= f.label :estimate_accuracy_class, "Estimate accuracy class", class: "font-label-caps text-label-caps text-on-surface-variant uppercase block mb-1" %>
          <%= f.select :estimate_accuracy_class,
                [ [ "Class 2 (Detailed)", "class_2" ], [ "Class 3 (Semi-Detailed)", "class_3" ], [ "Class 4 (Study)", "class_4" ] ],
                { include_blank: "—" },
                class: "w-full bg-surface border border-outline-variant rounded p-2 font-body-md text-body-md text-on-surface focus:border-primary focus:ring-1 focus:ring-primary transition-colors" %>
        </div>
        <div>
          <label class="font-label-caps text-label-caps text-on-surface-variant uppercase block mb-1">Currency (read-only)</label>
          <div class="w-full bg-surface-container border border-outline-variant rounded p-2 font-tabular-numeric text-tabular-numeric text-on-surface">
            <%= @project.currency_iso %>
          </div>
        </div>
        <div>
          <%= f.label :base_year, class: "font-label-caps text-label-caps text-on-surface-variant uppercase block mb-1" %>
          <%= f.number_field :base_year, class: "w-full bg-surface border border-outline-variant rounded p-2 font-tabular-numeric text-tabular-numeric text-on-surface focus:border-primary focus:ring-1 focus:ring-primary transition-colors" %>
        </div>
        <%= f.submit "Save scope parameters", class: "w-full bg-primary text-on-primary py-2 rounded font-body-md font-semibold hover:bg-tertiary transition-colors" %>
      <% end %>
    </div>
  </div>

  <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm">
    <div class="flex items-center justify-between mb-4 border-b border-outline-variant pb-2">
      <h2 class="font-headline-md text-headline-md text-primary">Validation Feedback</h2>
      <span class="bg-surface-container-low border border-outline-variant text-on-surface-variant px-2 py-1 rounded font-label-caps text-label-caps flex items-center gap-1">
        <span class="material-symbols-outlined text-[14px]">hourglass_empty</span>
        Parser not wired yet
      </span>
    </div>
    <p class="font-body-md text-on-surface-variant mb-4">Row-level validation, zero-tolerance reconciliation, and preview totals will appear here after the import service is connected.</p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <div class="p-4 bg-surface border border-outline-variant rounded flex flex-col">
        <span class="font-label-caps text-label-caps text-on-surface-variant uppercase mb-1">Total base cost</span>
        <span class="font-tabular-numeric text-tabular-numeric text-lg font-bold text-primary">—</span>
      </div>
      <div class="p-4 bg-surface border border-outline-variant rounded flex flex-col">
        <span class="font-label-caps text-label-caps text-on-surface-variant uppercase mb-1">Line items</span>
        <span class="font-tabular-numeric text-tabular-numeric text-lg font-bold text-primary"><%= @project.line_items.count %></span>
      </div>
      <div class="p-4 bg-surface border border-outline-variant rounded flex flex-col">
        <span class="font-label-caps text-label-caps text-on-surface-variant uppercase mb-1">Cost packages</span>
        <span class="font-tabular-numeric text-tabular-numeric text-lg font-bold text-primary"><%= @project.category_values.where(dimension: :package).distinct.count(:name) %></span>
      </div>
      <div class="p-4 bg-surface border border-outline-variant rounded flex flex-col">
        <span class="font-label-caps text-label-caps text-on-surface-variant uppercase mb-1">Warnings</span>
        <span class="font-tabular-numeric text-tabular-numeric text-lg font-bold text-secondary-container">0</span>
      </div>
    </div>
  </div>

  <div class="flex justify-end mt-2 pt-6 border-t border-outline-variant">
    <button type="button" disabled class="opacity-50 cursor-not-allowed bg-secondary-container text-on-secondary font-semibold text-body-lg px-8 py-4 rounded shadow-sm flex items-center gap-2 uppercase tracking-wide">
      <span class="material-symbols-outlined">save</span>
      Commit import
    </button>
  </div>
</div>
